# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string.
# Local (docker compose): postgresql://postgres:postgres@localhost:5432/dealership?schema=public
# Production: your Neon connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dealership?schema=public"

# JWT signing secret (use a long random string) and token lifetime.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="1d"

# Seeded admin account (created by `npm run seed`).
ADMIN_EMAIL="admin@dealership.com"
ADMIN_PASSWORD="ChangeMe123!"

# API server port.
PORT="4000"

# Allowed frontend origin for CORS.
CORS_ORIGIN="http://localhost:5173"
