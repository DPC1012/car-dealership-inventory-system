{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://car-dealership-inventory-system-njrt.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
